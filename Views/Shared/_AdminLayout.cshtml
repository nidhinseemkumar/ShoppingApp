<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --sidebar-bg: #111827;
            --sidebar-hover: #1f2937;
            --sidebar-accent: #3b82f6;
            --content-bg: #f3f4f6;
            --topbar-height: 70px;
            --transition-speed: 0.3s;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--content-bg);
            overflow-x: hidden;
        }

        /* Sidebar Styles */
        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--sidebar-bg);
            color: #9ca3af;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 1000;
            transition: width var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1), left var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        #sidebar .sidebar-header {
            padding: 1.5rem;
            display: flex;
            align-items: center;
            color: #fff;
            white-space: nowrap;
            height: var(--topbar-height);
        }

        #sidebar .logo-icon {
            min-width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--sidebar-accent), #2563eb);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            margin-right: 15px;
        }

        #sidebar .logo-text {
            font-size: 1.25rem;
            font-weight: 700;
            transition: opacity var(--transition-speed);
        }

        #sidebar .nav-menu {
            flex-grow: 1;
            padding: 0 1rem;
            overflow-y: auto;
            overflow-x: hidden;
        }

        .nav-item {
            margin-bottom: 0.5rem;
        }

        .nav-link {
            color: #9ca3af;
            padding: 0.8rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            transition: all 0.2s ease;
            text-decoration: none;
            cursor: pointer;
            border: none;
            background: transparent;
            width: 100%;
            white-space: nowrap;
        }

        .nav-link:hover {
            color: #fff;
            background-color: var(--sidebar-hover);
        }

        .nav-link.active {
            color: #fff;
            background-color: var(--sidebar-accent);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
        }

        .nav-link i:first-child {
            min-width: 45px;
            font-size: 1.25rem;
            display: flex;
            justify-content: center;
        }

        .nav-link span {
            margin-left: 10px;
            transition: opacity var(--transition-speed);
        }

        /* Submenu */
        .submenu {
            padding-left: 55px;
            list-style: none;
            margin: 0;
            margin-bottom: 0.5rem;
            overflow: hidden;
        }

        .submenu li a {
            color: #6b7280;
            padding: 0.5rem 0;
            display: block;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.2s ease;
        }

        .submenu li a:hover, .submenu li a.active {
            color: #fff;
        }

        /* Chevron rotation */
        .nav-link[data-bs-toggle="collapse"] .bi-chevron-down {
            transition: transform 0.3s ease;
            margin-left: auto !important;
            font-size: 0.8rem;
        }

        .nav-link[data-bs-toggle="collapse"]:not(.collapsed) .bi-chevron-down {
            transform: rotate(180deg);
        }

        /* Main Content */
        #main-wrapper {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        }

        #topbar {
            height: var(--topbar-height);
            background-color: #fff;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .page-content {
            padding: 2rem;
            flex-grow: 1;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            #sidebar {
                left: calc(-1 * var(--sidebar-width));
                width: var(--sidebar-width) !important;
            }
            #sidebar.show {
                left: 0;
            }
            #main-wrapper {
                margin-left: 0 !important;
            }
        }

        /* UI Components */
        .card {
            border: none;
            border-radius: 1.25rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .btn-primary {
            background-color: var(--sidebar-accent);
            border-color: var(--sidebar-accent);
        }

        .btn-primary:hover {
            background-color: #2563eb;
            border-color: #2563eb;
        }

        .badge-soft-success { background-color: #d1fae5; color: #065f46; }
        .badge-soft-warning { background-color: #fef3c7; color: #92400e; }
        .badge-soft-danger { background-color: #fee2e2; color: #991b1b; }
        .badge-soft-primary { background-color: #dbeafe; color: #1e40af; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Sidebar -->
    <aside id="sidebar">
        <div class="sidebar-header">
            <div class="logo-icon">
                <i class="bi bi-lightning-charge-fill text-white fs-5"></i>
            </div>
            <div class="logo-text">
                <h4 class="fw-bold mb-0 text-white">BuyNext <span class="text-white-50 small">Admin</span></h4>
            </div>
        </div>

        <nav class="nav-menu">
            <div class="nav-item">
                <a asp-controller="Admin" asp-action="Dashboard" 
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </div>

            <div class="nav-item">
                @{
                    var isProductsActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" || 
                                         (ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && 
                                         (ViewContext.RouteData.Values["Action"]?.ToString() == "Products" || 
                                          ViewContext.RouteData.Values["Action"]?.ToString() == "Categories"));
                }
                <button class="nav-link @(isProductsActive ? "active" : "collapsed")" 
                        data-bs-toggle="collapse" data-bs-target="#productsSubmenu">
                    <i class="bi bi-box-seam"></i>
                    <span class="fw-bold">Products</span>
                    <i class="bi bi-chevron-down ms-auto"></i>
                </button>
                <div class="collapse @(isProductsActive ? "show" : "")" id="productsSubmenu">
                    <ul class="submenu">
                        <li><a asp-controller="Products" asp-action="Create" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" && ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active text-white fw-bold" : "")">Add Product</a></li>
                        <li><a asp-controller="Admin" asp-action="Products" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Products" ? "active text-white fw-bold" : "")">View Products</a></li>
                        <li><a asp-controller="Admin" asp-action="Categories" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Categories" ? "active text-white fw-bold" : "")">Categories</a></li>
                    </ul>
                </div>
            </div>

            <div class="nav-item">
                <a asp-controller="Users" asp-action="Index" 
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people"></i>
                    <span>Users</span>
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="Admin" asp-action="Orders" 
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="bi bi-cart3"></i>
                    <span>Orders</span>
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="Admin" asp-action="Reviews" 
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Reviews" ? "active" : "")">
                    <i class="bi bi-star"></i>
                    <span>Reviews</span>
                </a>
            </div>

            <div class="nav-item">
                @{
                    var isImportExportActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "Files";
                }
                <button class="nav-link @(isImportExportActive ? "active" : "collapsed")" 
                        data-bs-toggle="collapse" data-bs-target="#importExportSubmenu">
                    <i class="bi bi-arrow-left-right"></i>
                    <span class="fw-bold">Import / Export</span>
                    <i class="bi bi-chevron-down ms-auto"></i>
                </button>
                <div class="collapse @(isImportExportActive ? "show" : "")" id="importExportSubmenu">
                    <ul class="submenu">
                        <li><a href="#" data-bs-toggle="modal" data-bs-target="#importProductsModal">Import Products</a></li>
                        <li><a asp-controller="Files" asp-action="ExportProducts" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Files" && ViewContext.RouteData.Values["Action"]?.ToString() == "ExportProducts" ? "active text-white fw-bold" : "")">Export Products</a></li>
                        <li><a asp-controller="Files" asp-action="ExportUsers" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Files" && ViewContext.RouteData.Values["Action"]?.ToString() == "ExportUsers" ? "active text-white fw-bold" : "")">Export Users</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="p-4 mt-auto">
            <form asp-controller="Users" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary w-100 rounded-pill text-white-50 border-secondary-subtle">
                    <i class="bi bi-box-arrow-left me-2"></i>Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div id="main-wrapper">
        <header id="topbar">
            <button class="btn btn-light d-lg-none me-3" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <h4 class="fw-bold mb-0">@ViewData["Title"]</h4>
            
            <div class="ms-auto d-flex align-items-center">
                <div class="dropdown">
                    <button class="btn btn-light rounded-pill px-3 dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                        <div class="bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                            <i class="bi bi-person"></i>
                        </div>
                        <span class="d-none d-md-inline">@User.Identity?.Name</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end rounded-4 shadow-lg border-0 mt-2">
                        <li><a class="dropdown-item py-2" asp-controller="Users" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Users" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-left me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="page-content">
            @RenderBody()
        </main>

        <!-- Toast Notifications -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="successToast" class="toast align-items-center text-white bg-success border-0 rounded-4 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <span id="successToastMessage"></span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div id="errorToast" class="toast align-items-center text-white bg-danger border-0 rounded-4 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span id="errorToastMessage"></span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
        </div>

        <footer class="bg-white border-top py-3 px-4 text-center mt-auto">
            <p class="mb-0 text-muted small">&copy; 2026 BuyNext Admin Panel. All rights reserved.</p>
        </footer>
    </div>

    <!-- Import Modal -->
    <div class="modal fade" id="importProductsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-5">
                <div class="modal-header border-0 p-4">
                    <h5 class="modal-title fw-bold">Import Products</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Files" asp-action="ImportProducts" method="post" enctype="multipart/form-data">
                    <div class="modal-body p-4 pt-0">
                        <p class="text-muted small mb-4">Select a CSV file containing product data. Ensure the format matches our template.</p>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Upload File</label>
                            <input type="file" name="file" class="form-control rounded-pill px-3" accept=".csv" required>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Start Import</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebar = document.getElementById('sidebar');

        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            sidebar.classList.toggle('show');
        });

        // Toast Handler
        document.addEventListener('DOMContentLoaded', function() {
            const successMsg = '@TempData["SuccessMessage"]';
            const errorMsg = '@TempData["ErrorMessage"]';

            if (successMsg && successMsg !== '') {
                document.getElementById('successToastMessage').innerText = successMsg;
                const toast = new bootstrap.Toast(document.getElementById('successToast'));
                toast.show();
            }

            if (errorMsg && errorMsg !== '') {
                document.getElementById('errorToastMessage').innerText = errorMsg;
                const toast = new bootstrap.Toast(document.getElementById('errorToast'));
                toast.show();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
