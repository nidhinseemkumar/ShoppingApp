@inject ShoppingApp.Services.ICartService CartService
@inject ShoppingApp.Services.IProductService ProductService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuyNext</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8f9fa;
            padding-top: 100px; /* Space for floating navbar */
        }
        .navbar {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(15px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            padding: 0.5rem 1rem !important;
            margin: 1rem auto;
            border-radius: 20px;
            width: 95%;
            max-width: 1400px;
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.3);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
        }
        .nav-link {
            font-weight: 600;
            color: #495057 !important;
            transition: all 0.2s ease;
        }
        .nav-link:hover {
            color: #0d6efd !important;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.25rem;
            color: #000 !important;
        }
        .search-container {
            max-width: 500px;
            width: 100%;
        }
        @@media (max-width: 991.98px) {
            .navbar {
                width: 92%;
                margin: 0.5rem auto;
                border-radius: 15px;
            }
            .search-container {
                order: 3;
                margin: 1rem 0 0.5rem 0 !important;
                max-width: 100%;
            }
            .navbar-nav {
                order: 2;
                margin-bottom: 0 !important;
            }
            .d-flex.align-items-center.gap-3 {
                order: 1;
            }
        }
        .nav-icon-link {
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #f8f9fa;
        }
        .nav-icon-link:hover {
            background-color: #e9ecef;
            transform: translateY(-2px);
        }
        .cart-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            font-size: 0.65rem;
            padding: 0.35em 0.55em;
            border-radius: 50%;
            border: 2px solid #fff;
        }
        .search-input {
            border-radius: 12px;
        }
        .brand-text {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }
        .dropdown-item {
            border-radius: 8px;
            padding: 0.6rem 1rem;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="logo-icon bg-primary text-white me-2 rounded-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="bi bi-lightning-fill fs-6"></i>
                    </div>
                    <span class="brand-text">BuyNext</span>
                </a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="navbarContent">
                    <div class="d-flex align-items-center me-auto">
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-3 d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-grid-3x3-gap me-2"></i>Categories
                                </a>
                                <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-2 mt-2">
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" asp-controller="Products" asp-action="Index">
                                            <div class="bg-primary-subtle text-primary rounded-3 p-1 me-2" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-collection-fill small"></i>
                                            </div>
                                            All Products
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    @{
                                        var categories = await ProductService.GetCategoriesAsync();
                                        if (categories != null)
                                        {
                                            foreach (var cat in categories)
                                            {
                                                <li>
                                                    <a class="dropdown-item d-flex align-items-center" asp-controller="Products" asp-action="Index" asp-route-category="@cat.CategoryName">
                                                        <i class="bi bi-chevron-right me-2 small text-muted"></i>
                                                        @cat.CategoryName
                                                    </a>
                                                </li>
                                            }
                                        }
                                    }
                                </ul>
                            </li>
                        </ul>
                    </div>

                    <form class="search-container mx-lg-4 my-2 my-lg-0 position-relative" asp-controller="Products" asp-action="Index" method="get">
                        <div class="position-relative">
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                            <input id="mainSearchInput" class="form-control search-input ps-5 py-2 bg-light border-0 shadow-none" type="search" name="searchTerm" placeholder="Search for groceries, electronics..." aria-label="Search" autocomplete="off">
                        </div>
                        <div id="searchSuggestions" class="dropdown-menu border-0 shadow-lg rounded-4 p-2 mt-2 w-100 position-absolute" style="display: none; top: 100%;"></div>
                    </form>

                    <div class="d-flex align-items-center gap-3">

                        <a class="nav-icon-link position-relative text-dark text-decoration-none" asp-controller="Carts" asp-action="Index" title="Cart">
                            <i class="bi bi-cart2 fs-4"></i>
                            @{
                                var cartCount = 0;
                                if (User.Identity?.IsAuthenticated == true)
                                {
                                    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                    if (int.TryParse(userIdStr, out int userId))
                                    {
                                        cartCount = await CartService.GetCartCountAsync(userId);
                                    }
                                }
                            }
                            <span class="badge bg-primary cart-badge">@cartCount</span>
                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown ms-2">
                                <a class="nav-icon-link dropdown-toggle no-caret" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person fs-4"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li class="px-3 py-2 border-bottom mb-2">
                                        <div class="fw-bold">@User.Identity!.Name</div>
                                        <div class="small text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
                                    </li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index"><i class="bi bi-box-seam me-2"></i>My Orders</a></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-primary fw-bold" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Products" asp-action="Index"><i class="bi bi-grid me-2"></i>Manage Products</a></li>
                                        <li><a class="dropdown-item" asp-controller="Users" asp-action="Index"><i class="bi bi-people me-2"></i>Manage Users</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Users" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="ms-3">
                                <a asp-controller="Users" asp-action="Login" class="btn btn-outline-primary rounded-pill px-4 fw-bold me-2">Login</a>
                                <a asp-controller="Users" asp-action="Signup" class="btn btn-primary rounded-pill px-4 fw-bold">Sign Up</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-4 mt-5">
        <div class="container text-center">
            &copy; 2026 - BuyNext - Premium Shopping Experience
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <style>
        .no-caret::after { display: none !important; }
    </style>
</body>
</html>
