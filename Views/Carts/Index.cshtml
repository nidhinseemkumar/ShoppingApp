@model IEnumerable<ShoppingApp.Models.Cart>

@{
    ViewData["Title"] = "Your Shopping Cart";
    decimal total = Model.Sum(item => (item.Product.Price ?? 0) * (item.Quantity ?? 0));
}

<div class="row">
    <div class="col-md-12 mb-4">
        <h1 class="font-weight-bold">🛒 Shopping Cart</h1>
        <p class="text-muted">Manage your items and proceed to checkout.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 shadow-sm bg-white rounded">
        <h3>Your cart is empty.</h3>
        <p class="text-muted">Explore our latest products on the home page.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4">Continue Shopping</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-4">Product</th>
                                <th class="border-0 text-center">Quantity</th>
                                <th class="border-0 text-right">Price</th>
                                <th class="border-0 text-right pr-4">Subtotal</th>
                                <th class="border-0"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var itemSubtotal = (item.Product.Price ?? 0) * (item.Quantity ?? 0);
                                <tr>
                                    <td class="align-middle px-4">
                                        <div class="font-weight-bold">@item.Product.Name</div>
                                    </td>
                                    <td class="align-middle text-center" style="width: 150px;">
                                        <div class="input-group input-group-sm justify-content-center">
                                            <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-change="-1" 
                                               class="btn btn-outline-secondary">-</a>
                                            <span class="form-control text-center font-weight-bold" style="max-width: 50px;">@item.Quantity</span>
                                            <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-change="1" 
                                               class="btn btn-outline-secondary">+</a>
                                        </div>
                                    </td>
                                    <td class="align-middle text-right">₹@item.Product.Price</td>
                                    <td class="align-middle text-right pr-4">₹@itemSubtotal</td>
                                    <td class="align-middle text-right pr-3">
                                        <a asp-action="Delete" asp-route-id="@item.CartId" class="text-danger" title="Remove Item">
                                            <span style="font-size: 1.2rem;">&times;</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title font-weight-bold mb-4">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Items Total</span>
                        <span>₹@total</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Delivery</span>
                        <span class="text-success">FREE</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4 font-weight-bold">
                        <span class="h5">Total</span>
                        <span class="h5 text-primary">₹@total</span>
                    </div>
                    <a asp-action="Checkout" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm">Proceed to Checkout</a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">Continue Shopping</a>
                </div>
            </div>
        </div>
    </div>
}
