@model ShoppingApp.Models.Product

@{
    ViewData["Title"] = "Add New Product";
    var categories = ViewBag.AllCategories as IEnumerable<ShoppingApp.Models.Category>;
}

<div class="container mt-2 mb-5">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-primary-subtle text-primary rounded-4 p-2 me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-plus-circle-fill fs-4"></i>
        </div>
        <h4 class="fw-bold mb-0">Add New Product</h4>
    </div>
    <div class="card border-0 shadow-lg rounded-5 p-4">
        <div class="card-body">
            <form asp-action="Create" id="createProductForm" class="needs-validation" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 px-3 mb-4 small"></div>

                <div class="row g-4">
                    <!-- Left Column: Basic Info -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="bg-light p-4 rounded-4 h-100">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold small text-uppercase tracking-wider">Product Name</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-tag text-muted"></i></span>
                                    <input asp-for="Name" id="productName" list="productSuggestions" autocomplete="off" class="form-control bg-white border-0 py-3" placeholder="Enter product name..." required pattern="^[a-zA-Z0-9\s\-_(),]+$" />
                                    <datalist id="productSuggestions"></datalist>
                                </div>
                            </div>

                            <div id="duplicateAlerts" class="mb-4" style="display: none;">
                                <div id="globalRejection" class="alert alert-danger border-0 shadow-sm rounded-4 py-2 small mb-0 d-flex align-items-center" style="display: none;">
                                    <i class="bi bi-x-circle-fill fs-5 me-2"></i> 
                                    <div><strong>Error:</strong> A product with this name already exists in the database.</div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Description" class="form-label fw-bold small text-uppercase tracking-wider">Product Description</label>
                                <textarea asp-for="Description" id="productDesc" class="form-control bg-white border-0 py-3" rows="4" placeholder="Provide a detailed description of the product features and specifications..." required></textarea>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label fw-bold small text-uppercase tracking-wider">Unit Price (₹)</label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-currency-rupee text-muted"></i></span>
                                        <input asp-for="Price" id="productPrice" type="number" step="0.01" class="form-control bg-white border-0 py-3" placeholder="0.00" required min="0.01" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Stock" class="form-label fw-bold small text-uppercase tracking-wider">Initial Stock</label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-stack text-muted"></i></span>
                                        <input asp-for="Stock" id="productStock" type="number" class="form-control bg-white border-0 py-3" placeholder="0" required min="0" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Meta & Image -->
                    <div class="col-xl-4 col-lg-5">
                        <div class="bg-light p-4 rounded-4 h-100 d-flex flex-column">
                            <div class="mb-4">
                                <label for="categoryName" class="form-label fw-bold small text-uppercase tracking-wider">Product Category</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-grid text-muted"></i></span>
                                    <select name="categoryName" id="categoryInput" class="form-select bg-white border-0 py-3 shadow-none" required>
                                        <option value="" selected disabled>Choose a category...</option>
                                        @if (categories != null)
                                        {
                                            @foreach (var cat in categories)
                                            {
                                                <option value="@cat.CategoryName">@cat.CategoryName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                
                                <div class="mt-3">
                                    <p class="x-small fw-bold text-muted text-uppercase mb-2">Quick Select</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        @if (categories != null)
                                        {
                                            @foreach (var cat in categories.Take(6))
                                            {
                                                <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1 x-small fw-bold" 
                                                        onclick="selectCategory('@cat.CategoryName')">
                                                    @cat.CategoryName
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="mt-2 text-end">
                                    <a asp-action="Categories" asp-controller="Admin" target="_blank" class="x-small text-decoration-none">
                                        <i class="bi bi-plus-lg me-1"></i>Manage Categories
                                    </a>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold small text-uppercase tracking-wider">Product Image Links</label>
                                <div id="imageLinksContainer">
                                    <div class="input-group mb-2">
                                        <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-link-45deg text-muted"></i></span>
                                        <input name="imageUrls" class="form-control bg-white border-0 py-3 image-link-input" placeholder="Paste image URL here..." required type="url" oninput="updatePreviews()" />
                                        <button type="button" class="btn btn-white border-0 text-danger" onclick="removeLink(this)" style="display: none;"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-primary btn-sm rounded-pill mt-2" onclick="addLink()">
                                    <i class="bi bi-plus-lg me-1"></i> Add Another Link
                                </button>
                                <div class="mt-2 text-muted x-small d-flex align-items-center">
                                    <i class="bi bi-info-circle me-1"></i> 
                                    <span>Links must start with <strong>https://</strong> or <strong>http://</strong></span>
                                </div>
                            </div>

                            <div class="flex-grow-1 d-flex flex-column">
                                <label class="form-label fw-bold small text-uppercase tracking-wider">Live Preview</label>
                                <div class="preview-box border-0 rounded-4 bg-white p-3 shadow-inner overflow-auto" style="flex-grow: 1; min-height: 200px;">
                                    <div id="imagePreviewContainer" class="row g-2">
                                        <div class="col-12 text-center py-5 text-muted">
                                            <i class="bi bi-image fs-1 d-block mb-2 opacity-25"></i>
                                            <span>No Valid URLs</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="button" onclick="showConfirmationModal()" class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-bold shadow flex-grow-1">
                        <i class="bi bi-shield-check me-2"></i>Review & Create Product
                    </button>
                    <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-outline-secondary btn-lg rounded-pill px-5 py-3 fw-bold">
                        Discard
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-5">
            <div class="modal-header bg-primary text-white border-0 py-3 px-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-question-circle me-2"></i>Confirm Product Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row">
                    <div class="col-md-5">
                        <div id="modalImageCarousel" class="carousel slide preview-image-container p-2 border rounded-4 bg-light mb-3" data-bs-ride="carousel">
                            <div class="carousel-inner" id="modalCarouselInner">
                                <!-- Images will be injected here -->
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#modalImageCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#modalImageCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="mb-2">
                            <span class="text-muted small">Name</span>
                            <h4 id="previewName" class="fw-bold mb-0"></h4>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small">Category</span>
                            <div><span id="previewCategory" class="badge bg-secondary-subtle text-secondary rounded-pill"></span></div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-6">
                                <span class="text-muted small">Price</span>
                                <div class="fw-bold text-primary">₹<span id="previewPrice"></span></div>
                            </div>
                            <div class="col-6">
                                <span class="text-muted small">Stock</span>
                                <div class="fw-bold"><span id="previewStock"></span> units</div>
                            </div>
                        </div>
                        <div>
                            <span class="text-muted small">Description</span>
                            <p id="previewDesc" class="text-secondary small"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Edit Details</button>
                <button type="button" onclick="confirmSubmit()" class="btn btn-primary rounded-pill px-5 fw-bold">Confirm & Add Product</button>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-box {
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        border: none !important;
    }
    .shadow-inner {
        box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05);
    }
    .tracking-wider {
        letter-spacing: 0.05em;
    }
    .x-small {
        font-size: 0.7rem;
    }

</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Live Suggestions and Duplicate Check
        const productNameInput = document.getElementById('productName');
        const categoryInput = document.getElementById('categoryInput');
        const productSuggestions = document.getElementById('productSuggestions');
        
        const duplicateAlerts = document.getElementById('duplicateAlerts');
        const globalRejection = document.getElementById('globalRejection');
        
        let debounceTimer;
        let isRejected = false;
        const confirmationModal = new bootstrap.Modal(document.getElementById('confirmationModal'));

        function runDuplicateCheck() {
            clearTimeout(debounceTimer);
            const name = productNameInput.value.trim();
            const category = categoryInput.value;
            
            if (name.length < 2) {
                duplicateAlerts.style.display = 'none';
                return;
            }

            debounceTimer = setTimeout(() => {
                const url = `/Products/CheckDuplicate?name=${encodeURIComponent(name)}&category=${encodeURIComponent(category || '')}`;
                fetch(url)
                    .then(response => response.json())
                    .then(data => {
                        isRejected = data.isGlobalDuplicate;
                        
                        if (data.isGlobalDuplicate) {
                            duplicateAlerts.style.display = 'block';
                            globalRejection.style.display = 'flex';
                            productNameInput.classList.add('is-invalid');
                            productNameInput.setCustomValidity('Product name already exists.');
                        } else {
                            duplicateAlerts.style.display = 'none';
                            globalRejection.style.display = 'none';
                            productNameInput.classList.remove('is-invalid');
                            productNameInput.setCustomValidity('');
                        }
                    });
                
                // Also update datalist suggestions
                fetch(`/Products/GetSuggestions?term=${encodeURIComponent(name)}`)
                    .then(response => response.json())
                    .then(data => {
                        productSuggestions.innerHTML = '';
                        data.forEach(n => {
                            const opt = document.createElement('option');
                            opt.value = n;
                            productSuggestions.appendChild(opt);
                        });
                    });
            }, 400);
        }

        productNameInput.addEventListener('input', runDuplicateCheck);
        categoryInput.addEventListener('change', runDuplicateCheck);

        function selectCategory(name) {
            categoryInput.value = name;
            runDuplicateCheck();
        }

        // Image Link Logic
        const imageLinksContainer = document.getElementById('imageLinksContainer');
        const imagePreviewContainer = document.getElementById('imagePreviewContainer');
        const modalCarouselInner = document.getElementById('modalCarouselInner');

        function addLink() {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `
                <span class="input-group-text bg-white border-0 px-3"><i class="bi bi-link-45deg text-muted"></i></span>
                <input name="imageUrls" class="form-control bg-white border-0 py-3 image-link-input" placeholder="Paste image URL here..." required type="url" oninput="updatePreviews()" />
                <button type="button" class="btn btn-white border-0 text-danger" onclick="removeLink(this)"><i class="bi bi-trash"></i></button>
            `;
            imageLinksContainer.appendChild(div);
            updatePreviews();
        }

        function removeLink(btn) {
            btn.closest('.input-group').remove();
            updatePreviews();
        }

        function updatePreviews() {
            const inputs = document.querySelectorAll('.image-link-input');
            imagePreviewContainer.innerHTML = '';
            let validCount = 0;

            inputs.forEach((input, index) => {
                const url = input.value.trim();
                if (url && input.checkValidity()) {
                    validCount++;
                    const col = document.createElement('div');
                    col.className = 'col-4';
                    col.innerHTML = `
                        <div class="position-relative">
                            <img src="${url}" class="img-fluid rounded-3 shadow-sm border ${validCount === 1 ? 'border-primary border-2' : ''}" style="height: 80px; width: 100%; object-fit: cover;" onerror="this.src='https://via.placeholder.com/80?text=Error'">
                            ${validCount === 1 ? '<span class="position-absolute top-0 end-0 badge rounded-circle bg-primary p-1 m-1 shadow-sm"><i class="bi bi-check-lg text-white"></i></span>' : ''}
                            ${validCount === 1 ? '<div class="x-small text-primary fw-bold text-center mt-1" style="font-size: 0.6rem;">MAIN</div>' : ''}
                        </div>
                    `;
                    imagePreviewContainer.appendChild(col);
                }
            });

            if (validCount === 0) {
                imagePreviewContainer.innerHTML = `
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-image fs-1 d-block mb-2 opacity-25"></i>
                        <span>No Valid URLs</span>
                    </div>
                `;
            }
        }

        function showConfirmationModal() {
            if (isRejected) {
                alert("Cannot proceed: A product with this name already exists in the database.");
                return;
            }

            const form = document.getElementById('createProductForm');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            document.getElementById('previewName').innerText = document.getElementById('productName').value;
            document.getElementById('previewPrice').innerText = document.getElementById('productPrice').value;
            document.getElementById('previewStock').innerText = document.getElementById('productStock').value;
            document.getElementById('previewCategory').innerText = document.getElementById('categoryInput').value;
            
            // Populate Modal Carousel
            modalCarouselInner.innerHTML = '';
            const inputs = document.querySelectorAll('.image-link-input');
            let hasImages = false;

            inputs.forEach((input, index) => {
                const url = input.value.trim();
                if (url && input.checkValidity()) {
                    hasImages = true;
                    const item = document.createElement('div');
                    item.className = `carousel-item ${!modalCarouselInner.children.length ? 'active' : ''}`;
                    item.innerHTML = `<img src="${url}" class="d-block w-100 rounded-3" style="max-height: 250px; object-fit: contain;">`;
                    modalCarouselInner.appendChild(item);
                }
            });

            if (!hasImages) {
                modalCarouselInner.innerHTML = `<div class="carousel-item active text-center py-5"><i class="bi bi-image fs-1 text-muted"></i><p>No valid image links</p></div>`;
            }
            
            // Limit preview description length
            const desc = document.getElementById('productDesc').value;
            document.getElementById('previewDesc').innerText = desc.length > 200 ? desc.substring(0, 200) + '...' : desc;
            
            confirmationModal.show();
        }

        function confirmSubmit() {
            document.getElementById('createProductForm').submit();
        }

        // Bootstrap Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
