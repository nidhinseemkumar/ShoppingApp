@using System.Globalization
@model ShoppingApp.DTOs.ProductDto

@{
    if (Model == null)
    {
        Context.Response.Redirect("/Home/Error");
        return;
    }
    ViewData["Title"] = Model.Name + " - Details";
    CultureInfo indianCulture = new CultureInfo("en-IN");
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="product-image-container p-4 rounded-5 bg-white shadow-sm border border-light">
                <img src="@(string.IsNullOrEmpty(Model?.ImageUrl) ? $"https://via.placeholder.com/600x600?text={Model?.Name}" : Model.ImageUrl)" 
                     class="img-fluid rounded-4 w-100" alt="@Model?.Name"
                     onerror="handleImageError(this)">
            </div>
        </div>
        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model!.Name</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-bold mb-2">@Model!.Name</h1>
            
            <div class="d-flex align-items-center mb-3">
                <div class="text-warning me-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(Model.AverageRating))
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                        else if (i - 0.5 <= Model.AverageRating)
                        {
                            <i class="bi bi-star-half"></i>
                        }
                        else
                        {
                            <i class="bi bi-star"></i>
                        }
                    }
                </div>
                <span class="fw-bold me-1">@Model.AverageRating.ToString("0.0")</span>
                <span class="text-muted">(@Model.ReviewCount reviews)</span>
            </div>

            <p class="text-muted mb-4">Category: <span class="badge bg-secondary">@Model.CategoryName</span></p>
            
            <div class="d-flex align-items-center mb-4">
                <h2 class="text-primary fw-bold me-3 mb-0">₹@Model.Price.ToString("N2", indianCulture)</h2>
                @if (!User.IsInRole("Customer"))
                {
                    @if (Model.Stock > 0)
                    {
                        <span class="badge bg-success-subtle text-success border border-success rounded-pill px-3">In Stock (@Model.Stock)</span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill px-3">Out of Stock</span>
                    }
                }
            </div>

            <p class="lead text-secondary mb-5">
                @Model.Description
            </p>

            <div class="row g-3">
                <div class="col-sm-6">
                    @{
                        var cartItems = ViewData["UserCart"] as IEnumerable<ShoppingApp.Models.Cart>;
                        var cartItem = cartItems?.FirstOrDefault(c => c.ProductId == Model.ProductId);
                    }

                    @if (cartItem != null)
                    {
                        <div class="input-group input-group-lg shadow-sm rounded-pill border overflow-hidden">
                            <button onclick="updateCart(@Model.ProductId, -1, this)" class="btn btn-light border-0 px-4">
                                <i class="bi bi-dash-lg"></i>
                            </button>
                            <span class="input-group-text bg-white border-0 fw-bold px-4 flex-grow-1 justify-content-center fs-4 cart-quantity">@cartItem.Quantity</span>
                            <button onclick="updateCart(@Model.ProductId, 1, this)" class="btn btn-light border-0 px-4">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <button onclick="updateCart(@Model.ProductId, 1, this)" 
                           class="btn btn-outline-primary btn-lg w-100 rounded-pill shadow-sm">
                            <i class="bi bi-cart-plus me-2"></i>Add to Cart
                        </button>
                    }
                </div>
                <div class="col-sm-6">
                    <a asp-controller="Carts" asp-action="BuyNow" asp-route-productId="@Model.ProductId" 
                       class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm">
                        <i class="bi bi-lightning-fill me-2"></i>Buy Now
                    </a>
                </div>
            </div>

            <hr class="my-5 text-muted">
            
            <div class="d-flex align-items-center gap-3">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model?.ProductId" class="btn btn-link text-decoration-none p-0 text-dark">
                        <i class="bi bi-pencil-square me-1"></i>Edit Product
                    </a>
                    <span class="text-muted">|</span>
                }
                <a asp-action="Index" class="btn btn-link text-decoration-none p-0 text-dark">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5">
        <div class="col-lg-8">
            <h3 class="mb-4">Customer Reviews</h3>
            
            @if (TempData["ReviewMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["ReviewMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- User Review Form -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="card border-0 shadow-sm rounded-4 mb-5">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">@(Model!.UserReview != null ? "Update Your Review" : "Write a Review")</h5>
                        <form asp-controller="Reviews" asp-action="SubmitReview" method="post">
                            <input type="hidden" name="ProductId" value="@Model.ProductId" />
                            <div class="mb-3">
                                <label class="form-label">Rating</label>
                                <div class="rating-input d-flex gap-2 fs-3 text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star star-input cursor-pointer" data-value="@i"></i>
                                    }
                                    <input type="hidden" name="Rating" id="selected-rating" value="@(Model.UserReview?.Rating ?? 0)" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="Comment" class="form-label">Your Review</label>
                                <textarea class="form-control rounded-3" id="Comment" name="Comment" rows="3" placeholder="Share your thoughts about this product...">@Model.UserReview?.Comment</textarea>
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                @(Model.UserReview != null ? "Update Review" : "Submit Review")
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info rounded-4 border-0 shadow-sm mb-5">
                    <i class="bi bi-info-circle me-2"></i>Please <a asp-controller="Users" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="fw-bold">login</a> to write a review.
                </div>
            }

            <!-- Reviews List -->
            <div class="reviews-list">
                @if (Model!.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card border-0 shadow-sm rounded-4 mb-3">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="mb-0 fw-bold">@review.UserName</h6>
                                        <div class="text-warning small">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </div>
                                <p class="card-text text-secondary mb-0">@review.Comment</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-light rounded-4">
                        <i class="bi bi-chat-left-text display-4 text-muted mb-3 d-block"></i>
                        <p class="text-muted">No reviews yet. Be the first to review this product!</p>
                    </div>
                }
            </div>
        </div>
        
        <div class="col-lg-4">
            <!-- Rating Summary -->
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
                <div class="card-body p-4 text-center">
                    <h4 class="card-title mb-4">Rating Summary</h4>
                    <div class="display-3 fw-bold text-primary mb-2">@Model.AverageRating.ToString("0.0")</div>
                    <div class="text-warning mb-3 fs-4">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(Model.AverageRating))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else if (i - 0.5 <= Model.AverageRating)
                            {
                                <i class="bi bi-star-half"></i>
                            }
                            else
                            {
                                <i class="bi bi-star"></i>
                            }
                        }
                    </div>
                    <p class="text-muted mb-0">Based on @Model.ReviewCount reviews</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }
    .btn-primary {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        border: none;
    }
    .btn-primary:hover {
        background: linear-gradient(135deg, #0b5ed7 0%, #0a58ca 100%);
        transform: translateY(-2px);
    }
    .btn-outline-primary:hover {
        transform: translateY(-2px);
    }
    .card {
        transition: transform 0.3s ease;
    }
    .cursor-pointer {
        cursor: pointer;
    }
    .star-input:hover, .star-input.active {
        color: #ffc107;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const stars = document.querySelectorAll('.star-input');
        const ratingInput = document.getElementById('selected-rating');
        
        function updateStars(value) {
            stars.forEach(s => {
                const starValue = parseInt(s.getAttribute('data-value'));
                if (starValue <= value) {
                    s.classList.remove('bi-star');
                    s.classList.add('bi-star-fill');
                } else {
                    s.classList.remove('bi-star-fill');
                    s.classList.add('bi-star');
                }
            });
        }

        // Initialize stars if editing
        if (ratingInput && ratingInput.value > 0) {
            updateStars(parseInt(ratingInput.value));
        }

        stars.forEach(star => {
            star.addEventListener('click', function() {
                const value = parseInt(this.getAttribute('data-value'));
                ratingInput.value = value;
                updateStars(value);
            });

            star.addEventListener('mouseover', function() {
                const value = parseInt(this.getAttribute('data-value'));
                updateStars(value);
            });

            star.addEventListener('mouseout', function() {
                updateStars(parseInt(ratingInput.value) || 0);
            });
        });
    });
</script>
