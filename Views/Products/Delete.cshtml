@model ShoppingApp.Models.Product
@using System.Globalization

@{
    ViewData["Title"] = "Delete Product";
    CultureInfo indianCulture = new CultureInfo("en-IN");
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header bg-danger text-white py-4 px-5 text-center">
                    <i class="bi bi-exclamation-triangle-fill display-4 mb-3 d-block"></i>
                    <h2 class="fw-bold mb-0">Confirm Deletion</h2>
                    <p class="mb-0 text-white-50">This action cannot be undone.</p>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-light rounded-4 p-4 mb-3 d-inline-block shadow-sm">
                            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? $"https://via.placeholder.com/200x200?text={Model.Name}" : Model.ImageUrl)" 
                                 class="img-fluid rounded-3" style="max-height: 200px;" alt="@Model.Name">
                        </div>
                        <h3 class="fw-bold text-dark">@Model.Name</h3>
                        <p class="text-muted">Are you absolutely sure you want to remove this product from the inventory?</p>
                    </div>

                    <div class="bg-light rounded-4 p-4 mb-4 border border-light">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Price:</span>
                            <span class="fw-bold text-dark">₹@((Model.Price ?? 0m).ToString("N2", indianCulture))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Stock Level:</span>
                            <span class="fw-bold @(Model.Stock < 10 ? "text-danger" : "text-success")">@Model.Stock Units</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Product ID:</span>
                            <span class="fw-bold text-dark">#@Model.ProductId</span>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ProductId" />
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill py-3 fw-bold shadow">
                                <i class="bi bi-trash3-fill me-2"></i>Delete Permanently
                            </button>
                            <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-outline-secondary btn-lg rounded-pill py-3 fw-bold">
                                <i class="bi bi-x-lg me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        animation: slideUp 0.5s ease;
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
