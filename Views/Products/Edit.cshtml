@model ShoppingApp.Models.Product

@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.AllCategories as IEnumerable<ShoppingApp.Models.Category>;
    // Find current category name
    var currentCategoryName = categories?.FirstOrDefault(c => c.CategoryId == Model.CategoryId)?.CategoryName ?? "";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header bg-dark text-white py-4 px-5">
                    <div class="d-flex align-items-center">
                        <div class="icon-box bg-white text-dark rounded-4 p-2 me-3 shadow-sm">
                            <i class="bi bi-pencil-square fs-3"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-0">Edit Product</h2>
                            <p class="mb-0 text-white-50">Modify product details and inventory status.</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Edit" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>
                        <input type="hidden" asp-for="ProductId" />

                        <div class="row g-4 mb-4">
                            <!-- Product Name -->
                            <div class="col-md-12">
                                <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 rounded-start-4 px-3"><i class="bi bi-tag text-muted"></i></span>
                                    <input asp-for="Name" class="form-control bg-light border-0 rounded-end-4 py-3" placeholder="Product Name" required pattern="^[a-zA-Z0-9\s\-_(),]+$" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small ms-2"></span>
                            </div>

                            <!-- Description -->
                            <div class="col-md-12">
                                <label asp-for="Description" class="form-label fw-bold">Description</label>
                                <textarea asp-for="Description" class="form-control bg-light border-0 rounded-4 py-3" rows="3" placeholder="Product Description" required></textarea>
                                <span asp-validation-for="Description" class="text-danger small ms-2"></span>
                            </div>

                            <!-- Price & Stock -->
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-bold">Price (₹)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 rounded-start-4 px-3"><i class="bi bi-currency-rupee text-muted"></i></span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control bg-light border-0 rounded-end-4 py-3" required min="0.01" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small ms-2"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label fw-bold">Stock Quantity</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 rounded-start-4 px-3"><i class="bi bi-stack text-muted"></i></span>
                                    <input asp-for="Stock" type="number" class="form-control bg-light border-0 rounded-end-4 py-3" required min="0" />
                                </div>
                                <span asp-validation-for="Stock" class="text-danger small ms-2"></span>
                            </div>

                            <!-- Category Autocomplete -->
                            <div class="col-md-12">
                                <label for="categoryName" class="form-label fw-bold">Category</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 rounded-start-4 px-3"><i class="bi bi-grid text-muted"></i></span>
                                    <input name="categoryName" list="categoryOptions" class="form-control bg-light border-0 rounded-end-4 py-3" 
                                           placeholder="Category" required id="categoryInput" value="@currentCategoryName" />
                                    <datalist id="categoryOptions">
                                        @if (categories != null)
                                        {
                                            @foreach (var cat in categories)
                                            {
                                                <option value="@cat.CategoryName"></option>
                                            }
                                        }
                                    </datalist>
                                </div>
                                <div id="newCategoryBadge" class="mt-2" style="display: none;">
                                    <span class="badge bg-info-subtle text-info rounded-pill px-3 py-2 border border-info-subtle">
                                        <i class="bi bi-stars me-1"></i> New Category will be created
                                    </span>
                                </div>
                            </div>

                            <!-- Image URL -->
                            <div class="col-md-12">
                                <label asp-for="ImageUrl" class="form-label fw-bold">Product Image URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 rounded-start-4 px-3"><i class="bi bi-image text-muted"></i></span>
                                    <input asp-for="ImageUrl" class="form-control bg-light border-0 rounded-end-4 py-3" placeholder="Image URL" required type="url" />
                                </div>
                                <span asp-validation-for="ImageUrl" class="text-danger small ms-2"></span>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-3 mt-5">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill px-5 py-3 fw-bold shadow flex-grow-1">
                                <i class="bi bi-save2-fill me-2"></i>Save Changes
                            </button>
                            <a asp-action="Delete" asp-route-id="@Model.ProductId" class="btn btn-outline-danger btn-lg rounded-pill px-4 py-3 fw-bold shadow-sm">
                                <i class="bi bi-trash3-fill me-2"></i>Delete Product
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4 py-3 fw-bold">
                                Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-box {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(33, 37, 41, 0.15);
        border: 1px solid rgba(33, 37, 41, 0.5) !important;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const categoryInput = document.getElementById('categoryInput');
        const categoryOptions = document.getElementById('categoryOptions');
        const newCategoryBadge = document.getElementById('newCategoryBadge');
        
        const existingCategories = Array.from(categoryOptions.options).map(opt => opt.value.toLowerCase());

        categoryInput.addEventListener('input', function() {
            const val = this.value.trim().toLowerCase();
            if (val && !existingCategories.includes(val)) {
                newCategoryBadge.style.display = 'block';
            } else {
                newCategoryBadge.style.display = 'none';
            }
        });

        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
