@{
    ViewData["Title"] = "Dashboard Overview";
    Layout = "_AdminLayout";
}

@if (ViewBag.LowStockProducts != null && ((IEnumerable<ShoppingApp.Models.Product>)ViewBag.LowStockProducts).Any())
{

        <div class="alert alert-warning border-0 shadow-sm rounded-5 p-4 mb-5 animate__animated animate__headShake">
            <div class="d-flex align-items-center mb-3">
                <div class="icon-box bg-warning-subtle text-warning rounded-circle p-2 me-3">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">Inventory Alert: Low Stock Detected</h5>
                    <p class="small text-dark opacity-75 mb-0">The following items are running low and may need restocking soon.</p>
                </div>
            </div>
            <div class="row g-2">
                @foreach (var item in (IEnumerable<ShoppingApp.Models.Product>)ViewBag.LowStockProducts)
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="bg-white rounded-4 p-2 px-3 border border-warning-subtle d-flex justify-content-between align-items-center">
                            <span class="small fw-bold text-truncate me-2" style="max-width: 150px;">@item.Name</span>
                            <span class="badge @(item.Stock == 0 ? "bg-danger" : "bg-warning text-dark") rounded-pill">@item.Stock left</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Stats Row -->
    @using System.Globalization
    @{ var indianCulture = new CultureInfo("en-IN"); }
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-primary text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Total Products</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.ProductCount</h2>
                </div>
                <i class="bi bi-box-seam position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-success text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Total Revenue</h6>
                    <h2 class="display-6 fw-bold mb-0">₹@(((decimal)ViewBag.TotalSales).ToString("N0", indianCulture))</h2>
                </div>
                <i class="bi bi-currency-rupee position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-info text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Order Volume</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.OrderCount</h2>
                </div>
                <i class="bi bi-cart-check position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-warning text-dark position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-dark-50 text-uppercase fw-bold small mb-3">Active Users</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.UserCount</h2>
                </div>
                <i class="bi bi-people position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Main Management Cards -->
    <div class="row g-4 mt-2">
        <!-- Main Management Cards -->
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-primary-subtle text-primary rounded-4 p-2 me-3">
                        <i class="bi bi-grid-fill fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Products Catalog</h5>
                </div>
                <div class="d-flex gap-2">
                    <a asp-controller="Admin" asp-action="Products" class="btn btn-light rounded-pill py-2 fw-bold border small flex-grow-1">Manage</a>
                    <a asp-controller="Files" asp-action="ExportProducts" class="btn btn-outline-dark rounded-pill py-2 small fw-bold border-0 bg-light px-3" title="Export CSV">
                        <i class="bi bi-download"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-success-subtle text-success rounded-4 p-2 me-3">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">User Accounts</h5>
                </div>
                <div class="d-flex gap-2">
                    <a asp-controller="Users" asp-action="Index" class="btn btn-light rounded-pill py-2 fw-bold border small flex-grow-1">Manage</a>
                    <a asp-controller="Files" asp-action="ExportUsers" class="btn btn-outline-dark rounded-pill py-2 small fw-bold border-0 bg-light px-3" title="Export CSV">
                        <i class="bi bi-download"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-info-subtle text-info rounded-4 p-2 me-3">
                        <i class="bi bi-upload fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Quick Import</h5>
                </div>
                <form asp-controller="Files" asp-action="ImportProducts" method="post" enctype="multipart/form-data" class="d-flex gap-2">
                    <input class="form-control form-control-sm rounded-pill px-3 bg-light border-0" type="file" name="file" accept=".csv" required>
                    <button type="submit" class="btn btn-info text-white rounded-pill px-3 fw-bold shadow-sm small">
                        <i class="bi bi-check-lg"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-4 mt-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <h5 class="fw-bold mb-4">Sales Trend (Last 7 Days)</h5>
                <canvas id="salesChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <h5 class="fw-bold mb-4">Sales by Category</h5>
                <canvas id="categoryChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Data Tables Section -->
    <div class="row g-4 mt-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Recent Orders</h5>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-link text-primary p-0 text-decoration-none small fw-bold">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="text-muted small">
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in ViewBag.RecentOrders)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">#@order.OrderId</td>
                                    <td>@order.User?.FirstName</td>
                                    <td class="small text-muted">@order.OrderDate.ToString("MMM dd")</td>
                                    <td class="text-end fw-bold">₹@order.TotalAmount?.ToString("N0", indianCulture)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <h5 class="fw-bold mb-4">Top Selling Products</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="text-muted small">
                                <th>Product Name</th>
                                <th class="text-end">Quantity Sold</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.TopProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3">@item.Quantity</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-4 rounded-4 shadow-sm border-0 d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-4"></i>
            <div>@TempData["Message"]</div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Sales Trend Chart
        const salesTrendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SalesTrend));
        const salesCtx = document.getElementById('salesChart').getContext('2d');
        new Chart(salesCtx, {
            type: 'line',
            data: {
                labels: salesTrendData.map(d => d.Date),
                datasets: [{
                    label: 'Revenue (₹)',
                    data: salesTrendData.map(d => d.Sales),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3,
                    pointBackgroundColor: '#0d6efd',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        grid: { display: false }
                    },
                    x: { grid: { display: false } }
                }
            }
        });

        // Category Chart
        const categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CategorySales));
        const categoryCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: categoryData.map(d => d.Category),
                datasets: [{
                    data: categoryData.map(d => d.Sales),
                    backgroundColor: [
                        '#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#6f42c1', '#fd7e14'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                },
                cutout: '70%'
            }
        });
    </script>
}

<style>
    .icon-box {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .table thead th {
        font-weight: 700;
        border-top: none;
    }
</style>
