@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="display-4 fw-bold mb-0">Admin <span class="text-primary">Dashboard</span></h1>
            <p class="lead text-muted mt-2">Welcome back. Here's what's happening with BuyNext today.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="d-inline-flex gap-2">
                <a asp-controller="Products" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow">
                    <i class="bi bi-plus-lg me-2"></i>New Product
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-shop me-2"></i>View Store
                </a>
            </div>
        </div>
    </div>

    <!-- Stats Row -->
    @using System.Globalization
    @{ var indianCulture = new CultureInfo("en-IN"); }
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-primary text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Total Products</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.ProductCount</h2>
                </div>
                <i class="bi bi-box-seam position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-success text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Total Revenue</h6>
                    <h2 class="display-6 fw-bold mb-0">₹@(((decimal)ViewBag.TotalSales).ToString("N0", indianCulture))</h2>
                </div>
                <i class="bi bi-currency-rupee position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-info text-white position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-white-50 text-uppercase fw-bold small mb-3">Order Volume</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.OrderCount</h2>
                </div>
                <i class="bi bi-cart-check position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-lg rounded-5 p-4 bg-warning text-dark position-relative overflow-hidden h-100">
                <div class="position-relative z-1">
                    <h6 class="text-dark-50 text-uppercase fw-bold small mb-3">Active Users</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.UserCount</h2>
                </div>
                <i class="bi bi-people position-absolute end-0 bottom-0 m-3 opacity-25" style="font-size: 4rem;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Main Management Cards -->
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-primary-subtle text-primary rounded-4 p-3 me-3">
                        <i class="bi bi-grid-fill fs-3"></i>
                    </div>
                    <h4 class="fw-bold mb-0">Product Catalog</h4>
                </div>
                <p class="text-muted mb-4">Add, edit, or remove products from the store. Manage inventory and categories.</p>
                <div class="mt-auto d-grid gap-2">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-light rounded-pill py-2 fw-bold border">Open Catalog</a>
                    <a asp-controller="Files" asp-action="ExportProducts" class="btn btn-outline-dark rounded-pill py-2 small fw-bold">
                        <i class="bi bi-download me-2"></i>Export Products (CSV)
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-success-subtle text-success rounded-4 p-3 me-3">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <h4 class="fw-bold mb-0">User Management</h4>
                </div>
                <p class="text-muted mb-4">View and manage all registered customers. Check roles and profile information.</p>
                <div class="mt-auto d-grid gap-2">
                    <a asp-controller="Users" asp-action="Index" class="btn btn-light rounded-pill py-2 fw-bold border">Manage Users</a>
                    <a asp-controller="Files" asp-action="ExportUsers" class="btn btn-outline-dark rounded-pill py-2 small fw-bold">
                        <i class="bi bi-download me-2"></i>Export Users (CSV)
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-5 p-4 h-100">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-info-subtle text-info rounded-4 p-3 me-3">
                        <i class="bi bi-file-earmark-arrow-up-fill fs-3"></i>
                    </div>
                    <h4 class="fw-bold mb-0">Data Import</h4>
                </div>
                <p class="text-muted mb-4">Bulk upload products into the system using a CSV file. Ensure correct format.</p>
                <form asp-controller="Files" asp-action="ImportProducts" method="post" enctype="multipart/form-data" class="mt-auto">
                    <div class="mb-3">
                        <input class="form-control form-control-sm rounded-3" type="file" name="file" accept=".csv" required>
                    </div>
                    <button type="submit" class="btn btn-info text-white rounded-pill w-100 py-2 fw-bold shadow-sm">
                        <i class="bi bi-upload me-2"></i>Import Products
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-4 rounded-4 shadow-sm border-0 d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-4"></i>
            <div>@TempData["Message"]</div>
        </div>
    }
</div>

<style>
    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
