@model IEnumerable<ShoppingApp.Models.Category>

@{
    ViewData["Title"] = "Category Management";
    Layout = "_AdminLayout";
}

<style>
    .hover-primary:hover { color: var(--sidebar-accent) !important; }
    .hover-opacity:hover { opacity: 0.8; }
</style>

<div class="row g-4 animate__animated animate__fadeIn">
    <!-- Category Form -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-5 p-4 sticky-top" style="top: 100px;">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-primary-subtle text-primary p-2 rounded-3 me-3">
                    <i class="bi bi-grid-fill fs-4"></i>
                </div>
                <h5 class="fw-bold mb-0">Create Category</h5>
            </div>
            <form asp-controller="Admin" asp-action="CreateCategory" method="post" class="needs-validation" novalidate>
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted text-uppercase">Category Name</label>
                    <input type="text" name="categoryName" class="form-control rounded-pill px-3 py-2 border-0 bg-light" placeholder="e.g. Smart Home" required>
                    <div class="invalid-feedback ps-2">Please enter a category name.</div>
                </div>
                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                    <i class="bi bi-plus-lg me-2"></i>Create Category
                </button>
            </form>
            
            <div class="mt-4 p-3 bg-light rounded-4">
                <h6 class="fw-bold small mb-2"><i class="bi bi-info-circle me-2"></i>Quick Tip</h6>
                <p class="text-muted small mb-0">Categories help organize your inventory and make searching easier for customers.</p>
            </div>
        </div>
    </div>

    <!-- Category List -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-5 overflow-hidden">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Existing Categories</h5>
                    <span class="badge bg-light text-dark rounded-pill px-3">Total: @Model.Count()</span>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase fw-bold">
                            <th class="ps-4">Category Name</th>
                            <th>Products Count</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            <i class="bi bi-folder2-open"></i>
                                        </div>
                                        <a asp-action="Products" asp-controller="Admin" asp-route-category="@cat.CategoryName" class="text-decoration-none">
                                            <h6 class="fw-bold mb-0 text-dark hover-primary">@cat.CategoryName</h6>
                                        </a>
                                    </div>
                                </td>
                                <td>
                                    <a asp-action="Products" asp-controller="Admin" asp-route-category="@cat.CategoryName" class="text-decoration-none">
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 hover-opacity">
                                            <i class="bi bi-box-seam me-1"></i> @(cat.Products?.Count() ?? 0) Items
                                        </span>
                                    </a>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <button class="btn btn-white btn-sm px-3 border-end" title="Edit" 
                                                onclick="editCategory(@cat.CategoryId, '@cat.CategoryName')">
                                            <i class="bi bi-pencil text-primary"></i>
                                        </button>
                                        <form asp-action="DeleteCategory" asp-route-id="@cat.CategoryId" method="post" 
                                              onsubmit="return confirm('Delete this category? This might affect products linked to it.')" class="d-inline">
                                            <button type="submit" class="btn btn-white btn-sm px-3" title="Delete">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateCategory" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="editCatId">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">New Name</label>
                        <input type="text" name="categoryName" id="editCatName" class="form-control rounded-pill px-3 py-2 border-0 bg-light" required>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const editModal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
        
        function editCategory(id, name) {
            document.getElementById('editCatId').value = id;
            document.getElementById('editCatName').value = name;
            editModal.show();
        }

        // Form Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
