@model IEnumerable<ShoppingApp.DTOs.UserDto>

@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <p class="text-muted mb-0">Total Accounts: <span class="fw-bold text-dark">@Model.Count()</span></p>
    </div>
    <div class="col-md-6 text-md-end">
        <a asp-controller="Users" asp-action="Signup" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus me-2"></i>Add New User
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-5 overflow-hidden">
    <div class="card-header bg-white py-3 px-4 border-bottom">
        <div class="row align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 rounded-start-pill ps-3"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="userSearch" class="form-control bg-light border-0 rounded-end-pill py-2" placeholder="Search users by name or email...">
                </div>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="usersTable">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase fw-bold">
                    <th class="ps-4">User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined Date</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold shadow-sm" 
                                     style="width: 42px; height: 42px;">
                                    @user.FirstName?[0]@user.LastName?[0]
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0">@user.FirstName @user.LastName</h6>
                                    <span class="text-muted small">@user.Phone</span>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-1 border border-danger-subtle">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-info-subtle text-info rounded-pill px-3 py-1 border border-info-subtle">Customer</span>
                            }
                        </td>
                        <td class="text-muted small">Apr 24, 2026</td> @* This should be dynamic if available *@
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                <a asp-controller="Users" asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-white btn-sm px-3 border-end">
                                    <i class="bi bi-pencil text-primary"></i>
                                </a>
                                <a asp-controller="Users" asp-action="Delete" asp-route-id="@user.UserId" class="btn btn-white btn-sm px-3">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('userSearch').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#usersTable tbody tr');
            
            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    </script>
}
