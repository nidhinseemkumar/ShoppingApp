@using System.Globalization
@model ShoppingApp.Models.Order

@{
    ViewData["Title"] = $"Order #{Model.OrderId} Details";
    Layout = "_AdminLayout";
    var indianCulture = new CultureInfo("en-IN");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    @Html.AntiForgeryToken()
    <div>
        <a asp-action="Orders" class="btn btn-link text-decoration-none text-muted p-0 mb-2">
            <i class="bi bi-arrow-left me-1"></i> Back to Orders
        </a>
        <h2 class="fw-bold mb-0">Order <span class="text-primary">#@Model.OrderId</span></h2>
        <p class="text-muted mb-0">Placed on @Model.OrderDate?.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
    </div>
    <div class="d-flex gap-2">
        <div class="dropdown">
            <button class="btn btn-white shadow-sm rounded-pill px-4 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Update Status
            </button>
            <ul class="dropdown-menu dropdown-menu-end rounded-4 border-0 shadow-lg p-2 mt-2">
                <li><a class="dropdown-item py-2" href="#" onclick="updateStatus(@Model.OrderId, 'Pending')">Pending</a></li>
                <li><a class="dropdown-item py-2" href="#" onclick="updateStatus(@Model.OrderId, 'Processing')">Processing</a></li>
                <li><a class="dropdown-item py-2" href="#" onclick="updateStatus(@Model.OrderId, 'Shipped')">Shipped</a></li>
                <li><a class="dropdown-item py-2 text-success" href="#" onclick="updateStatus(@Model.OrderId, 'Delivered')">Delivered</a></li>
                <li><a class="dropdown-item py-2 text-danger" href="#" onclick="updateStatus(@Model.OrderId, 'Cancelled')">Cancelled</a></li>
            </ul>
        </div>
        <button class="btn btn-primary rounded-pill px-4 shadow" onclick="window.print()">
            <i class="bi bi-printer me-2"></i> Print Invoice
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Order Items & Payment -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold mb-0">Order Items</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase fw-bold">
                            <th class="ps-4">Product</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end pe-4">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-4 p-1 me-3" style="width: 60px; height: 60px;">
                                            <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "https://via.placeholder.com/60" : item.Product.ImageUrl)" 
                                                 class="img-fluid rounded-3 h-100 w-100 object-fit-contain" 
                                                 alt="@item.Product?.Name">
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">@item.Product?.Name</h6>
                                            <span class="text-muted small">@item.Product?.Category?.CategoryName</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">₹@((item.Price ?? 0).ToString("N2", indianCulture))</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end pe-4 fw-bold text-primary">₹@((item.Price * item.Quantity ?? 0).ToString("N2", indianCulture))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white py-4 px-4 border-top">
                <div class="row justify-content-end">
                    <div class="col-md-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-bold">₹@((Model.TotalAmount ?? 0).ToString("N2", indianCulture))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping</span>
                            <span class="text-success fw-bold">Free</span>
                        </div>
                        <hr class="my-3">
                        <div class="d-flex justify-content-between">
                            <h5 class="fw-bold mb-0">Total Amount</h5>
                            <h5 class="fw-bold mb-0 text-primary">₹@((Model.TotalAmount ?? 0).ToString("N2", indianCulture))</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-5 overflow-hidden">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold mb-0">Payment History</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="text-muted small text-uppercase fw-bold">
                                <th class="ps-4">Payment ID</th>
                                <th>Method</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th class="text-end pe-4">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Payments.Any())
                            {
                                @foreach (var payment in Model.Payments)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@payment.PaymentId</td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>@payment.PaymentDate?.ToString("MMM dd, yyyy")</td>
                                        <td class="fw-bold">₹@((payment.Amount ?? 0).ToString("N2", indianCulture))</td>
                                        <td class="text-end pe-4">
                                            @{
                                                var payStatusClass = payment.PaymentStatus == "Completed" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning";
                                            }
                                            <span class="badge @payStatusClass rounded-pill px-3">@payment.PaymentStatus</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted small">No payments recorded for this order.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Customer & Status -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold mb-0">Order Status</h5>
            </div>
            <div class="card-body p-4 text-center">
                @{
                    var statusClass = Model.Status switch
                    {
                        "Pending" => "bg-warning-subtle text-warning",
                        "Processing" => "bg-info-subtle text-info",
                        "Shipped" => "bg-primary-subtle text-primary",
                        "Delivered" => "bg-success-subtle text-success",
                        "Cancelled" => "bg-danger-subtle text-danger",
                        _ => "bg-light text-muted"
                    };
                    
                    var icon = Model.Status switch
                    {
                        "Pending" => "bi-clock-history",
                        "Processing" => "bi-gear-wide-connected",
                        "Shipped" => "bi-truck",
                        "Delivered" => "bi-check-circle-fill",
                        "Cancelled" => "bi-x-circle-fill",
                        _ => "bi-question-circle"
                    };
                }
                <div class="mb-3">
                    <div class="display-4 @statusClass.Split(' ')[1] mb-2">
                        <i class="bi @icon"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@Model.Status</h3>
                </div>
                <p class="text-muted small">Current status of the order. Use the buttons at the top to change this status.</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold mb-0">Customer Information</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-weight: 700;">
                        @(Model.User?.FirstName?[0] ?? 'U')
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">@Model.User?.FirstName @Model.User?.LastName</h6>
                        <span class="text-muted small">ID: #@Model.UserId</span>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block mb-1">Email Address</label>
                    <p class="mb-0 fw-semibold">@Model.User?.Email</p>
                </div>
                
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block mb-1">Phone Number</label>
                    <p class="mb-0 fw-semibold">@(Model.User?.Phone ?? "Not Provided")</p>
                </div>

                <hr class="my-4">

                <div>
                    <label class="text-muted small text-uppercase fw-bold d-block mb-1">Shipping Address</label>
                    <p class="mb-0 fw-semibold">@(Model.User?.Address ?? "No address specified")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function updateStatus(orderId, status) {
            if (!confirm(`Are you sure you want to mark order #${orderId} as ${status}?`)) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch(`/Admin/UpdateOrderStatus`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `orderId=${orderId}&status=${status}`
                });

                if (response.ok) {
                    location.reload();
                } else {
                    const data = await response.json().catch(() => ({}));
                    alert(`Failed to update status: ${data.error || response.statusText || 'Unknown error'}`);
                }
            } catch (err) {
                console.error(err);
                alert('Error updating status');
            }
        }
    </script>
}

<style>
    .bg-success-subtle { background-color: #d1fae5; }
    .bg-warning-subtle { background-color: #fef3c7; }
    .bg-info-subtle { background-color: #e0f2fe; }
    .bg-primary-subtle { background-color: #dbeafe; }
    .bg-danger-subtle { background-color: #fee2e2; }
    
    .text-success { color: #059669 !important; }
    .text-warning { color: #d97706 !important; }
    .text-info { color: #0284c7 !important; }
    .text-primary { color: #2563eb !important; }
    .text-danger { color: #dc2626 !important; }

    @@media print {
        #sidebar, #topbar, .btn, .dropdown, footer { display: none !important; }
        #main-wrapper { margin-left: 0 !important; }
        .page-content { padding: 0 !important; }
        .card { border: 1px solid #eee !important; box-shadow: none !important; }
    }
</style>
