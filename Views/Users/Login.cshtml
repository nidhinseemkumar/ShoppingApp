@model ShoppingApp.Models.User

@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="card shadow">
            <div class="card-body">
                <h2 class="text-center mb-4">Sign In</h2>
                <form asp-action="Login" method="post" autocomplete="off">
                    <div class="form-group mb-3">
                        <label for="Email" class="control-label">Email</label>
                        <input name="Email" type="email" class="form-control" required autocomplete="off" />
                    </div>
                    <div class="form-group mb-3">
                        <label for="Password" class="control-label">Password</label>
                        <input name="Password" type="password" class="form-control" required autocomplete="new-password" spellcheck="false" />
                    </div>
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary w-100 mb-3">Sign In</button>
                        <p class="mb-0 text-muted">Don't have an account? <a asp-action="Signup">Sign Up</a></p>
                    </div>
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3">@ViewBag.Error</div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>
