@model ShoppingApp.DTOs.UserDto

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header bg-primary py-5 text-center position-relative">
                    <div class="position-absolute top-100 start-50 translate-middle">
                        <img src="https://ui-avatars.com/api/?name=@(Model.FirstName)+@(Model.LastName)&size=120&background=random&color=fff&bold=true" 
                             class="rounded-circle border border-4 border-white shadow-lg" alt="Profile">
                    </div>
                </div>
                <div class="card-body pt-5 mt-4 text-center pb-5">
                    <h3 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h3>
                    <p class="text-muted small mb-4">@Model.Email</p>
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 mb-4">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value User</span>
                    
                    <div class="d-grid gap-2 px-4">
                        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary rounded-pill py-2 fw-bold">
                            <i class="bi bi-pencil-square me-2"></i>Edit Profile
                        </a>
                        <form asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-danger rounded-pill py-2 fw-bold w-100 mt-2">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-5 p-4 p-md-5">
                <h4 class="fw-bold mb-5 d-flex align-items-center">
                    <i class="bi bi-person-badge text-primary me-3 fs-3"></i>Account Details
                </h4>

                <div class="info-grid">
                    <div class="info-row mb-4">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-muted small text-uppercase fw-bold letter-spacing-1">Full Name</div>
                            <div class="col-md-8 fs-5 fw-semibold mt-1 mt-md-0">@Model.FirstName @Model.LastName</div>
                        </div>
                    </div>
                    <hr class="my-4 opacity-5">
                    
                    <div class="info-row mb-4">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-muted small text-uppercase fw-bold letter-spacing-1">Email Address</div>
                            <div class="col-md-8 fs-5 fw-semibold mt-1 mt-md-0">@Model.Email</div>
                        </div>
                    </div>
                    <hr class="my-4 opacity-5">

                    <div class="info-row mb-4">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-muted small text-uppercase fw-bold letter-spacing-1">Phone Number</div>
                            <div class="col-md-8 fs-5 fw-semibold mt-1 mt-md-0">
                                @(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)
                            </div>
                        </div>
                    </div>
                    <hr class="my-4 opacity-5">

                    <div class="info-row mb-4">
                        <div class="row align-items-start">
                            <div class="col-md-4 text-muted small text-uppercase fw-bold letter-spacing-1">Shipping Address</div>
                            <div class="col-md-8 fs-5 fw-semibold mt-1 mt-md-0 text-secondary">
                                @(string.IsNullOrEmpty(Model.Address) ? "Not Provided" : Model.Address)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 p-4 bg-light rounded-4 border border-light">
                    <div class="d-flex align-items-center">
                        <div class="icon-box bg-white text-primary rounded-3 p-3 me-3 shadow-sm">
                            <i class="bi bi-clock-history fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Recent Activity</h6>
                            <p class="text-muted small mb-0">Check your latest orders and updates here.</p>
                        </div>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-white btn-sm shadow-sm rounded-pill ms-auto fw-bold px-3 border border-light">View Orders</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .opacity-5 { opacity: 0.05; }
    .btn-white:hover { background-color: #f8f9fa; }
</style>
