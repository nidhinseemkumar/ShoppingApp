@model ShoppingApp.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0 text-center p-4">
                <div class="mb-4">
                    <img src="https://ui-avatars.com/api/?name=@Model.Name&size=128&background=random" class="rounded-circle shadow" alt="User Profile Picture">
                </div>
                <h3>@Model.Name</h3>
                <p class="text-muted mb-4">@Model.Email</p>
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-outline-primary">Edit Profile</a>
                    <form asp-action="Logout" method="post" class="d-grid">
                        <button type="submit" class="btn btn-outline-danger mt-2">Log Out</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow border-0 p-4">
                <h4 class="mb-4">Account Information</h4>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Full Name</div>
                    <div class="col-sm-8 fw-bold">@Model.Name</div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Email Address</div>
                    <div class="col-sm-8 fw-bold">@Model.Email</div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Phone Number</div>
                    <div class="col-sm-8 fw-bold">@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Shipping Address</div>
                    <div class="col-sm-8 fw-bold">@(string.IsNullOrEmpty(Model.Address) ? "Not Provided" : Model.Address)</div>
                </div>
            </div>
        </div>
    </div>
</div>
