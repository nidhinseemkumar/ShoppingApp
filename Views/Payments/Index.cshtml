@{
    ViewData["Title"] = "Secure Payment";
    var orderId = ViewBag.OrderId;
    var productId = ViewBag.ProductId;
    var amount = ViewBag.Amount;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-5 bg-primary text-white p-5 d-flex flex-column justify-content-center">
                        <h2 class="fw-bold mb-4">Complete Your Payment</h2>
                        <div class="mb-4">
                            <p class="opacity-75 mb-1 text-uppercase small letter-spacing-1">Amount to Pay</p>
                            <h1 class="display-4 fw-bold">₹@amount</h1>
                        </div>
                        <div class="mt-auto">
                            <p class="small opacity-75"><i class="bi bi-shield-lock-fill me-2"></i>Secure encrypted transaction</p>
                        </div>
                    </div>
                    <div class="col-md-7 p-5 bg-white">
                        <h4 class="fw-bold mb-4 text-dark">Choose Payment Method</h4>
                        
                        <form asp-action="Process" method="post" id="paymentForm">
                            <input type="hidden" name="orderId" value="@orderId" />
                            <input type="hidden" name="productId" value="@productId" />
                            <input type="hidden" name="paymentMethod" id="selectedMethod" />

                            <div class="payment-options d-grid gap-3">
                                <div class="payment-item p-3 border rounded-4 d-flex align-items-center cursor-pointer transition-all" onclick="selectMethod('UPI')">
                                    <div class="icon-box bg-info-subtle text-info me-3 rounded-3 p-2">
                                        <i class="bi bi-phone fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-0">UPI (Google Pay, PhonePe)</h6>
                                        <small class="text-muted">Instant & Secure</small>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </div>

                                <div class="payment-item p-3 border rounded-4 d-flex align-items-center cursor-pointer transition-all" onclick="selectMethod('Card')">
                                    <div class="icon-box bg-primary-subtle text-primary me-3 rounded-3 p-2">
                                        <i class="bi bi-credit-card fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-0">Credit / Debit Card</h6>
                                        <small class="text-muted">Visa, Mastercard, RuPay</small>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </div>

                                <div class="payment-item p-3 border rounded-4 d-flex align-items-center cursor-pointer transition-all" onclick="selectMethod('NetBanking')">
                                    <div class="icon-box bg-success-subtle text-success me-3 rounded-3 p-2">
                                        <i class="bi bi-bank fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-0">Net Banking</h6>
                                        <small class="text-muted">All major Indian banks</small>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </div>

                                <div class="payment-item p-3 border rounded-4 d-flex align-items-center cursor-pointer transition-all" onclick="selectMethod('COD')">
                                    <div class="icon-box bg-warning-subtle text-warning me-3 rounded-3 p-2">
                                        <i class="bi bi-cash-stack fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-0">Cash on Delivery</h6>
                                        <small class="text-muted">Pay when you receive</small>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .payment-item:hover {
        border-color: #0d6efd !important;
        background-color: #f8f9fa;
        transform: translateX(5px);
    }
    .letter-spacing-1 { letter-spacing: 1px; }
    .transition-all { transition: all 0.2s ease; }
</style>

<script>
    function selectMethod(method) {
        document.getElementById('selectedMethod').value = method;
        document.getElementById('paymentForm').submit();
    }
</script>
